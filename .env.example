DEEPEVAL_API_KEY=your_deepeval_api_key_here

# Internal URLs (do not change in docker-compose environment)
# DATABASE_URL is auto-generated from POSTGRES_* variables
# REDIS_URL is auto-generated

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8000
