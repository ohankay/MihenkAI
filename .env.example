# PostgreSQL Configuration
POSTGRES_USER=mihenkai_user
POSTGRES_PASSWORD=secure_password
POSTGRES_DB=mihenkai_db

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
